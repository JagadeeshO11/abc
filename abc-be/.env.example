PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/itbees?schema=public"

# Auth
JWT_ACCESS_SECRET="your_access_secret"
JWT_REFRESH_SECRET="your_refresh_secret"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_..."
